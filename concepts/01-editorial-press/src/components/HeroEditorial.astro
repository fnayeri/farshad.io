---
import { profile } from "../lib/content.ts";
---

<section class="hero" aria-label="Editorial hero">
  <div class="container hero-grid">
    <div class="hero-meta">
      <div class="meta-row">
        <span class="meta-label">Volume</span>
        <span class="meta-value">I</span>
      </div>
      <div class="meta-row">
        <span class="meta-label">Edition</span>
        <span class="meta-value">First</span>
      </div>
      <div class="meta-row">
        <span class="meta-label">Imprint</span>
        <span class="meta-value">An Imprint of One</span>
      </div>
      <div class="meta-row">
        <span class="meta-label">Reading time</span>
        <span class="meta-value">90 sec</span>
      </div>
    </div>
    <div class="hero-display">
      <p class="kicker">A Personal Site, Set in One Volume</p>
      <h1 class="display">
        <span class="display-name">Farshad Nayeri</span>
      </h1>
      <p class="standfirst">
        <em>I take vague ideas — about products, organizations,</em>
        <br />
        <em>even whole categories — and turn them into things</em>
        <br />
        <em>that actually run.</em>
      </p>
      <div class="hero-byline">
        <span>Boston</span>
        <span class="byline-rule" aria-hidden="true"></span>
        <span>Builder &amp; Strategist</span>
        <span class="byline-rule" aria-hidden="true"></span>
        <span>{profile.email}</span>
      </div>
    </div>
    <aside class="hero-marginalia" aria-label="Editorial marginalia">
      <svg viewBox="0 0 200 240" class="micro-chart" aria-hidden="true">
        <defs>
          <linearGradient id="m3" x1="0" y1="1" x2="0" y2="0">
            <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.08" />
            <stop offset="100%" stop-color="var(--accent)" stop-opacity="0.5" />
          </linearGradient>
        </defs>
        <g class="bars">
          <rect x="14" y="180" width="14" height="40" />
          <rect x="36" y="160" width="14" height="60" />
          <rect x="58" y="120" width="14" height="100" />
          <rect x="80" y="100" width="14" height="120" />
          <rect x="102" y="70" width="14" height="150" />
          <rect x="124" y="50" width="14" height="170" />
          <rect x="146" y="35" width="14" height="185" />
          <rect x="168" y="20" width="14" height="200" />
        </g>
        <line x1="6" y1="220" x2="200" y2="220" stroke="var(--ink)" stroke-width="1" />
        <text x="6" y="14" class="caption">Apparent capability vs. tenure</text>
      </svg>
      <p class="marginalia-text">
        A small chart. Drawn by hand. The bars compound; the lineage is the point.
      </p>
    </aside>
  </div>
</section>

<style>
  .hero {
    border-bottom: 2px solid var(--ink);
    padding: clamp(40px, 8vw, 120px) 0 clamp(40px, 6vw, 80px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 200px minmax(0, 1fr) 220px;
    gap: clamp(24px, 4vw, 64px);
    align-items: start;
  }
  .hero-meta {
    border-top: 2px solid var(--ink);
    padding-top: 16px;
  }
  .meta-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--hairline);
    padding: 8px 0;
  }
  .meta-label {
    color: var(--ink-quiet);
    font-weight: 500;
  }
  .meta-value {
    color: var(--ink);
    font-weight: 700;
  }
  .kicker {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-quiet);
    margin: 0 0 18px;
  }
  .display {
    font-size: var(--step-5);
    line-height: 0.92;
    letter-spacing: -0.025em;
    margin: 0 0 24px;
    font-weight: 900;
  }
  .display-name {
    display: inline-block;
    background: linear-gradient(180deg, var(--ink) 70%, var(--accent) 70%, var(--accent) 72%, var(--ink) 72%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .standfirst {
    font-family: var(--serif-display);
    font-size: var(--step-2);
    line-height: 1.25;
    color: var(--ink-soft);
    margin: 0 0 28px;
    max-width: 22ch;
  }
  .standfirst em {
    font-style: italic;
  }
  .hero-byline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .byline-rule {
    display: inline-block;
    width: 16px;
    height: 1px;
    background: var(--ink-soft);
  }
  .hero-marginalia {
    border-left: 1px solid var(--hairline);
    padding-left: 22px;
    align-self: end;
  }
  .micro-chart {
    width: 100%;
    height: auto;
    margin-bottom: 12px;
  }
  .micro-chart .bars rect {
    fill: url(#m3);
    transform-origin: bottom;
    animation: barRise 900ms cubic-bezier(0.2, 0, 0.2, 1) backwards;
  }
  .micro-chart .bars rect:nth-of-type(1) { animation-delay: 0ms; }
  .micro-chart .bars rect:nth-of-type(2) { animation-delay: 60ms; }
  .micro-chart .bars rect:nth-of-type(3) { animation-delay: 120ms; }
  .micro-chart .bars rect:nth-of-type(4) { animation-delay: 180ms; }
  .micro-chart .bars rect:nth-of-type(5) { animation-delay: 240ms; }
  .micro-chart .bars rect:nth-of-type(6) { animation-delay: 300ms; }
  .micro-chart .bars rect:nth-of-type(7) { animation-delay: 360ms; }
  .micro-chart .bars rect:nth-of-type(8) { animation-delay: 420ms; }
  .micro-chart .caption {
    font-family: "Inter", sans-serif;
    font-size: 9px;
    fill: var(--ink-quiet);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  @keyframes barRise {
    from { transform: scaleY(0); opacity: 0; }
    to { transform: scaleY(1); opacity: 1; }
  }
  .marginalia-text {
    font-family: var(--serif-display);
    font-style: italic;
    font-size: 13px;
    line-height: 1.45;
    color: var(--ink-quiet);
    margin: 0;
  }
  @media (max-width: 1080px) {
    .hero-grid { grid-template-columns: 180px minmax(0, 1fr); }
    .hero-marginalia { grid-column: 1 / -1; border-left: 0; padding-left: 0; padding-top: 24px; border-top: 1px solid var(--rule); display: grid; grid-template-columns: 200px 1fr; gap: 22px; }
  }
  @media (max-width: 700px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-marginalia { grid-template-columns: 1fr; }
    .display { font-size: clamp(3.4rem, 14vw, 5rem); }
  }
</style>

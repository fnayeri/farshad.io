---
import { profile } from "../lib/content.ts";
---

<section class="cine-hero">
  <div class="container">
    <div class="cine-frame letterbox-bars" aria-hidden="false">
      <div class="cine-content">
        <p class="kicker">Direction · Boston</p>
        <h1 class="cine-title">
          <span class="line line-1">A builder</span>
          <span class="line line-2">who directs</span>
          <span class="line line-3">the data.</span>
        </h1>
        <p class="cine-throughline">{profile.throughline}</p>
        <div class="cine-meta">
          <span class="meta-pill"><span class="meta-pill-key">Email</span><span class="meta-pill-val">{profile.email}</span></span>
          <span class="meta-pill"><span class="meta-pill-key">Studio</span><span class="meta-pill-val">{profile.location}</span></span>
        </div>
      </div>
      <svg class="scene-chart" viewBox="0 0 600 320" aria-hidden="true">
        <defs>
          <linearGradient id="amber" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%" stop-color="#e8b547" stop-opacity="0" />
            <stop offset="100%" stop-color="#e8b547" stop-opacity="1" />
          </linearGradient>
          <linearGradient id="amberFill" x1="0" x2="0" y1="0" y2="1">
            <stop offset="0%" stop-color="#e8b547" stop-opacity="0.22" />
            <stop offset="100%" stop-color="#e8b547" stop-opacity="0" />
          </linearGradient>
        </defs>
        <g class="grid">
          <line x1="0" x2="600" y1="80" y2="80" />
          <line x1="0" x2="600" y1="160" y2="160" />
          <line x1="0" x2="600" y1="240" y2="240" />
        </g>
        <path class="area"
          d="M0 240 L 50 220 L 110 232 L 170 200 L 230 210 L 290 170 L 350 152 L 410 130 L 470 92 L 540 65 L 600 50 L 600 320 L 0 320 Z" />
        <path class="line"
          d="M0 240 L 50 220 L 110 232 L 170 200 L 230 210 L 290 170 L 350 152 L 410 130 L 470 92 L 540 65 L 600 50" />
        <circle class="dot" cx="540" cy="65" r="5" />
        <circle class="dot dot-pulse" cx="540" cy="65" r="14" />
        <text class="annot" x="468" y="46">Pixxa Perspective</text>
        <text class="annot annot-2" x="220" y="195">Critical Mass · 1996</text>
      </svg>
    </div>
  </div>
</section>

<style>
  .cine-hero {
    padding: clamp(28px, 4vw, 60px) 0 clamp(40px, 6vw, 80px);
  }
  .cine-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    background: radial-gradient(ellipse at 30% 20%, rgba(31, 59, 91, 0.5), transparent 65%), var(--film-2);
    border: 1px solid var(--rule-dark);
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .cine-content {
    position: relative;
    z-index: 2;
    padding: clamp(28px, 5vw, 64px) clamp(28px, 5vw, 80px);
    max-width: 56ch;
  }
  .kicker {
    font-family: var(--display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--highlight);
    margin: 0 0 18px;
  }
  .cine-title {
    font-size: var(--step-5);
    line-height: 0.92;
    font-weight: 200;
    letter-spacing: -0.04em;
    margin: 0 0 20px;
    color: var(--paper);
  }
  .cine-title .line {
    display: block;
    animation: lineUp 700ms cubic-bezier(0.2, 0, 0.2, 1) backwards;
  }
  .cine-title .line-1 { animation-delay: 80ms; }
  .cine-title .line-2 { animation-delay: 220ms; }
  .cine-title .line-3 { color: var(--highlight); font-weight: 600; animation-delay: 360ms; }
  @keyframes lineUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .cine-throughline {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--halo);
    margin: 0 0 28px;
    max-width: 32ch;
  }
  .cine-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .meta-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    border: 1px solid var(--rule-dark);
    padding: 6px 12px;
    border-radius: 999px;
    font-family: var(--display);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .meta-pill-key {
    text-transform: uppercase;
    color: var(--halo);
    font-weight: 500;
  }
  .meta-pill-val {
    color: var(--paper);
    font-weight: 500;
    font-feature-settings: "tnum";
  }
  .scene-chart {
    position: absolute;
    inset: auto 0 0 auto;
    width: 56%;
    height: 70%;
    z-index: 1;
    opacity: 0.92;
  }
  .scene-chart .grid line {
    stroke: rgba(255, 255, 255, 0.06);
    stroke-width: 1;
  }
  .scene-chart .area {
    fill: url(#amberFill);
    animation: drawArea 1200ms cubic-bezier(0.2, 0, 0.2, 1) backwards;
    animation-delay: 380ms;
  }
  .scene-chart .line {
    fill: none;
    stroke: var(--highlight);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: drawLine 1200ms cubic-bezier(0.2, 0, 0.2, 1) forwards;
    animation-delay: 320ms;
  }
  .scene-chart .dot {
    fill: var(--highlight);
    transform-origin: 540px 65px;
    animation: pop 600ms cubic-bezier(0.2, 0, 0.2, 1) backwards;
    animation-delay: 1400ms;
  }
  .scene-chart .dot-pulse {
    fill: var(--highlight);
    fill-opacity: 0;
    stroke: var(--highlight);
    stroke-width: 1;
    animation: pulse 1800ms ease-out infinite;
    animation-delay: 1500ms;
  }
  .scene-chart .annot {
    font-family: "Inter", sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    fill: var(--halo);
    text-transform: uppercase;
  }
  .scene-chart .annot-2 { fill: var(--lens-blue-soft); }
  @keyframes drawLine { to { stroke-dashoffset: 0; } }
  @keyframes drawArea { from { opacity: 0; } to { opacity: 1; } }
  @keyframes pop { from { transform: scale(0); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  @keyframes pulse {
    0% { transform: scale(0.5); opacity: 0.6; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @media (max-width: 900px) {
    .cine-frame { aspect-ratio: auto; }
    .scene-chart { display: none; }
  }
</style>

---
import Base from "../../layouts/Base.astro";
import { projects, getProjectModule, personas as allPersonas } from "../../lib/content.ts";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const mod = getProjectModule(slug!);
if (!mod) throw new Error("Project not found: " + slug);
const { frontmatter, Content } = mod;
const personaLabels = frontmatter.personas
  .map((id) => allPersonas.find((p) => p.id === id)?.label)
  .filter(Boolean);
---

<Base title={`${frontmatter.title} — Farshad Nayeri`} description={frontmatter.outcome} active="work" surface="paper">
  <article class="container case">
    <header class="case-head">
      <p class="kicker">Case · {frontmatter.dates}</p>
      <h1>{frontmatter.title}</h1>
      <p class="outcome">{frontmatter.outcome}</p>
    </header>

    <div class="case-grid">
      <aside class="meta">
        <dl>
          <div><dt>Client</dt><dd>{frontmatter.client}</dd></div>
          <div><dt>Role</dt><dd>{frontmatter.role}</dd></div>
          <div><dt>Dates</dt><dd>{frontmatter.dates}</dd></div>
          {frontmatter.location && <div><dt>Location</dt><dd>{frontmatter.location}</dd></div>}
          {frontmatter.collaborators.length > 0 && (
            <div>
              <dt>Collaborators</dt>
              <dd>{frontmatter.collaborators.join(", ")}</dd>
            </div>
          )}
          {personaLabels.length > 0 && (
            <div>
              <dt>Lenses</dt>
              <dd>{personaLabels.join(" · ")}</dd>
            </div>
          )}
        </dl>
      </aside>
      <div class="prose">
        <Content />
        <p class="back"><a href="/work/">← All scenes</a></p>
      </div>
    </div>
  </article>
</Base>

<style>
  .case { padding-bottom: 56px; }
  .case-head {
    padding: clamp(40px, 6vw, 96px) 0 28px;
    border-bottom: 1px solid var(--rule-light);
  }
  .kicker {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--lens-blue);
    margin: 0 0 14px;
    letter-spacing: 0.06em;
  }
  .case-head h1 {
    font-size: var(--step-4);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0 0 16px;
    font-weight: 300;
  }
  .outcome {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--ink-soft);
    margin: 0;
    max-width: 40ch;
  }
  .case-grid {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: clamp(24px, 4vw, 64px);
    padding: 40px 0;
  }
  .meta {
    border-top: 2px solid var(--ink);
  }
  .meta dl { margin: 0; }
  .meta div {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-bottom: 1px solid var(--rule-light);
    padding: 12px 0;
  }
  .meta dt {
    font-family: var(--display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-quiet);
    margin: 0;
  }
  .meta dd {
    margin: 0;
    font-family: var(--display);
    font-size: 14px;
    line-height: 1.4;
    color: var(--ink);
  }
  .prose :global(h2) {
    font-size: var(--step-1);
    margin-top: 32px;
    border-top: 1px solid var(--rule-light);
    padding-top: 18px;
  }
  .prose :global(h2:first-child),
  .prose :global(h2):first-of-type {
    margin-top: 0;
    border-top: 0;
    padding-top: 0;
  }
  .prose :global(p) {
    font-size: var(--step-0);
    line-height: 1.7;
    margin-bottom: 1em;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--highlight);
    padding-left: 18px;
    margin: 1.5em 0;
    font-style: italic;
    font-family: var(--serif);
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .back { margin-top: 28px; }
  .back a {
    font-family: var(--mono);
    font-size: 13px;
    border: 0;
    color: var(--lens-blue);
    border-bottom: 1px solid var(--lens-blue);
  }
  @media (max-width: 760px) {
    .case-grid { grid-template-columns: 1fr; }
  }
</style>

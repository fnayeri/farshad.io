---
import Base from "../layouts/Base.astro";
import { profile, testimonials, clients } from "../lib/content.ts";
---

<Base title="About — Farshad Nayeri" description="The long bio." active="about" surface="paper">
  <section class="container">
    <header class="head">
      <p class="kicker">Studio</p>
      <h1>About</h1>
      <p class="standfirst">{profile.throughline}</p>
    </header>
    <div class="grid">
      <aside class="meta">
        <div><dt>Location</dt><dd>{profile.location}</dd></div>
        <div><dt>Email</dt><dd><a href={`mailto:${profile.email}`}>{profile.email}</a></dd></div>
        <div><dt>LinkedIn</dt><dd><a href={profile.linkedin} target="_blank" rel="noopener noreferrer">linkedin.com/in/farshadnayeri</a></dd></div>
      </aside>
      <div class="bio">
        <h2>Four careers, one operator</h2>
        <p><strong>Programming-language and developer-tools researcher.</strong> GTE Labs (Distributed Object Manager, ECOOP 1994). The DEC SRC Modula-3 lineage. Verizon Labs.</p>
        <p><strong>Founder.</strong> Critical Mass, Inc. (Cambridge, 1995): commercial Modula-3, the Reactor / CM3-IDE in 1996, the Critical Mass JVM written entirely in Modula-3, class-compatible with Sun's JavaVM. Hired Bill Kalsow from DEC SRC. Edited <em>Threads: A Modula-3 Systems Journal</em> (1995–1997). Open-sourced in 2001. iGEN Corporation (1998–present). Pixxa LLC and the Perspective iPad app.</p>
        <p><strong>Data Cinematographer.</strong> Co-creator with Horace Dediu of the Airshow tour: Boston, Tokyo, Vancouver, London, San Francisco, Helsinki, Seattle, Melbourne (2013–2016). Co-author on Asymco. Invited speaker at HarvardXR 2025.</p>
        <p><strong>Christensen-trained strategist.</strong> Worked directly with Clayton Christensen and Dave Sundahl. Connected to the Christensen Institute and the dx.MBA / Product Science Lab. Strategy work at EY, Fidelity, Baupost, CME.</p>
        <h2>Press</h2>
        <div class="quotes">
          {testimonials.map((t) => (
            <figure class="q">
              <blockquote>{t.quote}</blockquote>
              <figcaption>
                <span class="qn">{t.name}</span>
                <span class="qt">{t.title}</span>
              </figcaption>
            </figure>
          ))}
        </div>
        <h2>Clients</h2>
        <ul class="client-track">
          {clients.map((c) => <li>{c}</li>)}
        </ul>
      </div>
    </div>
  </section>
</Base>

<style>
  .head { padding: clamp(40px, 6vw, 96px) 0 24px; }
  .kicker {
    font-family: var(--display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lens-blue);
    margin: 0 0 14px;
  }
  h1 { font-size: var(--step-5); line-height: 0.92; margin: 0 0 14px; font-weight: 200; letter-spacing: -0.04em; }
  .standfirst {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--ink-soft);
    margin: 0 0 28px;
    max-width: 36ch;
  }
  .grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: clamp(24px, 4vw, 64px);
  }
  .meta { border-top: 2px solid var(--ink); }
  .meta div {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-bottom: 1px solid var(--rule-light);
    padding: 12px 0;
  }
  .meta dt {
    font-family: var(--display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-quiet);
  }
  .meta dd { margin: 0; font-size: 14px; }
  .bio h2 {
    font-size: var(--step-1);
    border-top: 1px solid var(--rule-light);
    padding-top: 18px;
    margin-top: 32px;
  }
  .bio h2:first-of-type { margin-top: 0; border-top: 0; padding-top: 0; }
  .bio p { font-size: var(--step-0); line-height: 1.7; max-width: 64ch; }
  .quotes { display: grid; grid-template-columns: 1fr; gap: 0; }
  .q {
    margin: 0;
    border-top: 1px solid var(--rule-light);
    padding: 22px 0;
  }
  .q:first-of-type { border-top: 0; }
  .q blockquote {
    margin: 0 0 12px;
    border: 0;
    padding: 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.25;
  }
  .q blockquote::before { content: "“"; color: var(--highlight); }
  .q blockquote::after { content: "”"; color: var(--highlight); }
  .qn {
    font-family: var(--display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: 12px;
  }
  .qt { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--ink-quiet); }
  .client-track {
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
    font-family: var(--display);
    font-weight: 600;
    font-size: var(--step-2);
    letter-spacing: -0.02em;
  }
  .client-track li::after {
    content: " /";
    color: var(--highlight);
    margin-left: 8px;
  }
  .client-track li:last-child::after { content: ""; }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
</style>

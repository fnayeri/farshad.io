---
import Base from "../layouts/Base.astro";
import HeroLetterbox from "../components/HeroLetterbox.astro";
import LensSwitcher from "../components/LensSwitcher.astro";
import SceneCard from "../components/SceneCard.astro";
import { defaultPersona, projectsForPersona, testimonials, clients } from "../lib/content.ts";

const persona = defaultPersona();
const featured = projectsForPersona(persona.id).slice(0, 4);
const heroQuotes = testimonials.filter((t) => t.personas.includes(persona.id) || t.id === "gassee").slice(0, 3);
---

<Base title="Farshad Nayeri" description={persona.pitch_line} active="home">
  <HeroLetterbox />

  <div class="container">
    <LensSwitcher active={persona.id} />
  </div>

  <section class="container intro">
    <div class="intro-grid">
      <div>
        <p class="kicker">Now Reading As</p>
        <h2 class="intro-h">{persona.label}</h2>
        <p class="intro-pitch">{persona.pitch_line}</p>
        <p class="intro-body">{persona.what_he_uniquely_does}</p>
        <p>
          <a href={`/for/${persona.id}/`} class="cta">Open the cribsheet → /for/{persona.id}</a>
        </p>
      </div>
      <aside class="anchors">
        <div class="label">Credibility</div>
        <ol>
          {persona.credibility_anchors.map((a) => <li>{a}</li>)}
        </ol>
      </aside>
    </div>
  </section>

  <section class="container featured">
    <div class="section-head">
      <h3>Selected Scenes</h3>
      <a href="/work/" class="section-link">All work →</a>
    </div>
    <div class="scenes-grid">
      {featured.map((p) => <SceneCard project={p} />)}
    </div>
  </section>

  <section class="container press">
    <div class="section-head">
      <h3>Press</h3>
      <span class="section-link-quiet">From the Airshow tour</span>
    </div>
    <div class="quotes">
      {heroQuotes.map((t) => (
        <figure class="quote">
          <blockquote>{t.quote}</blockquote>
          <figcaption>
            <span class="quote-name">{t.name}</span>
            <span class="quote-title">{t.title}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="container clients">
    <div class="label">Clients</div>
    <ul class="client-track">
      {clients.map((c) => <li>{c}</li>)}
    </ul>
  </section>
</Base>

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: clamp(28px, 4vw, 64px);
    padding: 32px 0;
    border-top: 1px solid var(--rule-dark);
  }
  .kicker {
    font-family: var(--display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--highlight);
    margin: 0 0 12px;
  }
  .intro-h {
    font-size: var(--step-3);
    margin: 0 0 12px;
    font-weight: 200;
    letter-spacing: -0.03em;
  }
  .intro-pitch {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--halo);
    margin: 0 0 18px;
  }
  .intro-body {
    font-size: var(--step-0);
    line-height: 1.7;
    margin: 0 0 18px;
    max-width: 56ch;
  }
  .cta {
    display: inline-block;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--highlight);
    border-bottom: 1px solid var(--highlight);
  }
  .anchors {
    border-left: 1px solid var(--rule-dark);
    padding-left: 22px;
  }
  .anchors ol {
    list-style: decimal;
    padding-left: 1.2em;
    margin: 12px 0 0;
  }
  .anchors li {
    font-size: 13px;
    line-height: 1.55;
    color: var(--halo);
    margin-bottom: 12px;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--rule-dark);
    padding-top: 18px;
    margin: clamp(40px, 6vw, 72px) 0 24px;
  }
  .section-head h3 { margin: 0; font-size: var(--step-2); font-weight: 500; }
  .section-link {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--highlight);
    border-bottom: 1px solid var(--highlight);
  }
  .section-link-quiet {
    font-family: var(--serif);
    font-style: italic;
    color: var(--halo);
    font-size: 14px;
  }
  .scenes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
  }
  .quotes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 32px;
  }
  .quote {
    margin: 0;
    border-left: 1px solid var(--lens-blue-soft);
    padding-left: 22px;
  }
  .quote blockquote {
    margin: 0 0 14px;
    border: 0;
    padding: 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.25;
    color: var(--paper);
  }
  .quote blockquote::before { content: "“"; color: var(--highlight); }
  .quote blockquote::after { content: "”"; color: var(--highlight); }
  .quote-name {
    font-family: var(--display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: 12px;
    color: var(--paper);
  }
  .quote-title {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: var(--halo);
  }
  .clients {
    margin-top: 56px;
    border-top: 1px solid var(--rule-dark);
    padding: 28px 0 0;
  }
  .client-track {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
    font-family: var(--display);
    font-weight: 600;
    font-size: var(--step-2);
    letter-spacing: -0.02em;
  }
  .client-track li {
    color: var(--paper);
  }
  .client-track li::after {
    content: " /";
    color: var(--highlight);
    margin-left: 8px;
  }
  .client-track li:last-child::after { content: ""; }
  @media (max-width: 900px) {
    .intro-grid { grid-template-columns: 1fr; }
    .anchors { border-left: 0; padding-left: 0; padding-top: 18px; border-top: 1px solid var(--rule-dark); }
  }
</style>

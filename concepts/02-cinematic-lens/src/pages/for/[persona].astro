---
import Base from "../../layouts/Base.astro";
import LensSwitcher from "../../components/LensSwitcher.astro";
import SceneCard from "../../components/SceneCard.astro";
import {
  personas,
  testimonials,
  projects,
  getPersona,
  type Persona,
} from "../../lib/content.ts";

export function getStaticPaths() {
  return personas.map((p) => ({ params: { persona: p.id } }));
}

const { persona: personaId } = Astro.params;
const persona = getPersona(personaId!) as Persona;

const featured = persona.featured_project_slugs
  .map((slug) => projects.find((p) => p.slug === slug))
  .filter(Boolean) as typeof projects;
const personaQuotes = testimonials.filter((t) => t.personas.includes(persona.id));
---

<Base title={`${persona.label} — Farshad Nayeri`} description={persona.pitch_line} active="home">
  <section class="cine-persona">
    <div class="container">
      <div class="cine-frame letterbox-bars">
        <div class="cine-content">
          <p class="kicker">f/{personas.findIndex((p) => p.id === persona.id) + 1} · {persona.label}</p>
          <h1>{persona.pitch_line}</h1>
          <div class="actions">
            <a href="/work/" class="btn-ghost">Selected scenes →</a>
            <button type="button" class="btn-ghost" onclick="window.print();">Print one-pager</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <LensSwitcher active={persona.id} />
  </div>

  <section class="container body-grid">
    <div class="prose">
      <h2 class="h2-rule">The shape of the gap</h2>
      <p>{persona.shape_of_the_gap}</p>

      <h2 class="h2-rule">What he uniquely does</h2>
      <p>{persona.what_he_uniquely_does}</p>

      <h2 class="h2-rule">Angles to play</h2>
      <ul class="angles">
        {persona.angles_to_play.map((a) => <li>{a}</li>)}
      </ul>

      <h2 class="h2-rule">Heading off the wrong reads</h2>
      <p>{persona.head_off_early}</p>

      <p class="closing">{persona.closing_pitch}</p>
    </div>
    <aside class="sidebar">
      <div class="label">Credibility</div>
      <ol class="anchor-list">
        {persona.credibility_anchors.map((a) => <li>{a}</li>)}
      </ol>
      {personaQuotes.length > 0 && (
        <div class="press-block">
          <div class="label">Press</div>
          {personaQuotes.map((t) => (
            <figure class="mini-quote">
              <blockquote>{t.quote}</blockquote>
              <figcaption><b>{t.name}</b><span>{t.title}</span></figcaption>
            </figure>
          ))}
        </div>
      )}
    </aside>
  </section>

  <section class="container featured">
    <div class="section-head">
      <h3>Selected Scenes — {persona.label}</h3>
      <a href="/work/" class="section-link">All work →</a>
    </div>
    <div class="scenes-grid">
      {featured.map((p) => <SceneCard project={p} />)}
    </div>
  </section>
</Base>

<style>
  .cine-persona {
    padding: clamp(20px, 4vw, 48px) 0 clamp(40px, 5vw, 72px);
  }
  .cine-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    background:
      radial-gradient(ellipse at 70% 20%, rgba(31, 59, 91, 0.45), transparent 70%),
      radial-gradient(ellipse at 20% 90%, rgba(232, 181, 71, 0.16), transparent 60%),
      var(--film-2);
    border: 1px solid var(--rule-dark);
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .cine-content {
    padding: clamp(28px, 5vw, 64px) clamp(28px, 5vw, 80px);
    max-width: 60ch;
  }
  .kicker {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--highlight);
    margin: 0 0 18px;
    letter-spacing: 0.08em;
  }
  .cine-content h1 {
    font-size: var(--step-4);
    line-height: 1.05;
    font-weight: 200;
    letter-spacing: -0.03em;
    margin: 0 0 28px;
    color: var(--paper);
    max-width: 22ch;
  }
  .actions { display: flex; flex-wrap: wrap; gap: 14px; }
  .btn-ghost {
    display: inline-block;
    font-family: var(--display);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid var(--halo);
    padding: 10px 16px;
    border-radius: 999px;
    color: var(--paper);
    transition: background var(--t-quick), color var(--t-quick), border-color var(--t-quick);
  }
  .btn-ghost:hover { background: var(--highlight); color: var(--film); border-color: var(--highlight); }
  .body-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: clamp(28px, 4vw, 64px);
    margin-top: clamp(24px, 4vw, 48px);
  }
  .h2-rule {
    font-size: var(--step-1);
    margin-top: 32px;
    border-top: 1px solid var(--rule-dark);
    padding-top: 16px;
    color: var(--paper);
  }
  .h2-rule:first-of-type { margin-top: 0; border-top: 0; padding-top: 0; }
  .prose p {
    font-size: var(--step-0);
    line-height: 1.7;
    color: var(--halo);
  }
  .angles { padding-left: 1.2em; }
  .angles li { line-height: 1.6; margin-bottom: 8px; color: var(--halo); }
  .closing {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--paper);
    border-top: 1px solid var(--highlight);
    padding-top: 22px;
    margin-top: 32px;
  }
  .sidebar { border-left: 1px solid var(--rule-dark); padding-left: 22px; }
  .anchor-list {
    list-style: decimal;
    padding-left: 1.2em;
    margin: 14px 0 28px;
  }
  .anchor-list li {
    font-size: 13px;
    line-height: 1.55;
    color: var(--halo);
    margin-bottom: 12px;
  }
  .press-block { margin-top: 28px; }
  .mini-quote {
    margin: 14px 0;
    border-top: 1px solid var(--rule-dark);
    padding-top: 14px;
  }
  .mini-quote blockquote {
    margin: 0 0 8px;
    border: 0;
    padding: 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    line-height: 1.4;
    color: var(--paper);
  }
  .mini-quote figcaption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 11px;
    color: var(--halo);
  }
  .mini-quote figcaption b {
    color: var(--highlight);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--rule-dark);
    padding-top: 18px;
    margin: clamp(40px, 6vw, 72px) 0 24px;
  }
  .section-head h3 { margin: 0; font-size: var(--step-2); font-weight: 500; }
  .section-link { font-family: var(--mono); font-size: 12px; color: var(--highlight); border-bottom: 1px solid var(--highlight); }
  .scenes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
  }
  @media (max-width: 900px) {
    .body-grid { grid-template-columns: 1fr; }
    .sidebar { border-left: 0; padding-left: 0; border-top: 1px solid var(--rule-dark); padding-top: 18px; }
  }
</style>

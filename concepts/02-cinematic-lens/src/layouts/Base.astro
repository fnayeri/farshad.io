---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const {
  title,
  description = "Farshad Nayeri — builder, director, strategist.",
  active = "",
  surface = "film",
} = Astro.props as {
  title: string;
  description?: string;
  active?: string;
  surface?: "film" | "paper";
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={Astro.url.href} />
    <title>{title}</title>
  </head>
  <body class={surface === "paper" ? "surface-paper" : ""}>
    <a href="#main" class="skip">Skip to content</a>
    <Nav active={active} surface={surface} />
    <main id="main">
      <slot />
    </main>
    <Footer surface={surface} />
    <script is:inline>
      (function () {
        try {
          var p = window.location.pathname;
          var m = p.match(/^\/for\/([a-z\-]+)\/?$/);
          if (m && m[1]) localStorage.setItem("fn:persona", m[1]);
        } catch (e) {}
      })();
    </script>
  </body>
</html>

<style>
  .skip {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--highlight);
    color: var(--film);
    padding: 8px 12px;
    z-index: 100;
    border: 0;
  }
  .skip:focus { left: 12px; top: 12px; }
</style>

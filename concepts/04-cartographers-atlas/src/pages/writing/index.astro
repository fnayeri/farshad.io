---
import Base from "../../layouts/Base.astro";
import { writing } from "../../lib/content.ts";
---

<Base title="Field Notes — A Cartographer's Edition" description="Working notes from the journal." active="writing">
  <section class="container">
    <header class="head">
      <p class="series"><span class="banner">Field Notes</span> · A Working Journal</p>
      <h1>Field Notes</h1>
      <p class="lede"><em>Pages from the journal — drawn slowly, kept terse, occasionally illustrated.</em></p>
    </header>

    <ol class="notes">
      {writing.map((w, i) => (
        <li>
          <a href={`/writing/${w.slug}/`}>
            <span class="note-num">¶ {String(i + 1).padStart(2, "0")}</span>
            <span class="note-body">
              <strong>{w.title}</strong>
              <span class="note-date">{w.date}</span>
              <span class="note-desc">{w.description}</span>
            </span>
            <span class="note-arrow hand">→ read</span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</Base>

<style>
  .head { padding: clamp(40px, 6vw, 96px) 0 28px; max-width: 60ch; border-bottom: 1px solid var(--ink); }
  .series {
    font-family: var(--press-sc);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-quiet);
    margin: 0 0 18px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  h1 { font-size: var(--step-5); margin: 0 0 14px; }
  .lede { font-size: var(--step-1); color: var(--ink-soft); }
  .notes { list-style: none; margin: 32px 0 56px; padding: 0; }
  .notes li { border-top: 1px solid var(--rule); }
  .notes li:last-child { border-bottom: 1px solid var(--rule); }
  .notes a {
    display: grid;
    grid-template-columns: 60px minmax(0, 1fr) 100px;
    gap: 18px;
    padding: 22px 0;
    background: none;
    color: var(--ink);
    align-items: baseline;
  }
  .notes a:hover { background: var(--parchment-2); color: var(--ink); }
  .notes a:hover strong { color: var(--rust); }
  .note-num { color: var(--rust); font-family: var(--mono); font-size: 12px; }
  .notes strong { display: block; font-size: var(--step-2); margin-bottom: 2px; font-weight: 400; }
  .note-date { display: block; font-family: var(--mono); font-size: 12px; color: var(--ink-quiet); margin-bottom: 6px; }
  .note-desc { font-style: italic; color: var(--ink-soft); font-size: 14px; }
  .note-arrow { color: var(--rust); text-align: right; font-size: 18px; }
</style>

---
import Base from "../../layouts/Base.astro";
import { writing, getWritingModule } from "../../lib/content.ts";

export function getStaticPaths() {
  return writing.map((w) => ({ params: { slug: w.slug } }));
}

const { slug } = Astro.params;
const mod = getWritingModule(slug!);
if (!mod) throw new Error("Essay not found: " + slug);
const { frontmatter, Content } = mod;
---

<Base title={`${frontmatter.title} — A Cartographer's Edition`} description={frontmatter.description} active="writing">
  <article class="container">
    <header class="head">
      <p class="series"><span class="banner">Field Note</span> · {frontmatter.date}</p>
      <h1>{frontmatter.title}</h1>
      <p class="lede"><em>{frontmatter.description}</em></p>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .head { padding: clamp(40px, 6vw, 96px) 0 28px; max-width: 40em; border-bottom: 1px solid var(--ink); }
  .series {
    font-family: var(--press-sc);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-quiet);
    margin: 0 0 18px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  h1 { font-size: var(--step-4); margin: 0 0 14px; }
  .lede { font-size: var(--step-1); color: var(--ink-soft); margin: 0; }
  .prose { max-width: 38em; padding: 36px 0 56px; }
  .prose :global(p) { font-size: var(--step-0); line-height: 1.75; margin-bottom: 1em; }
  .prose :global(p:first-of-type)::first-letter {
    font-family: var(--press);
    font-size: 4em;
    float: left;
    line-height: 0.85;
    margin: 0.05em 0.08em 0 0;
    color: var(--rust);
  }
</style>

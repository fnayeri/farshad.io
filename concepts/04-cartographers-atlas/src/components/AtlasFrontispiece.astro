---
import { profile } from "../lib/content.ts";
---

<section class="frontispiece">
  <div class="container">
    <p class="series">A Cartographer's Edition · Volume I · Boston</p>
    <h1 class="title">
      <span class="title-line title-1">An Atlas</span>
      <span class="title-amp">&amp;</span>
      <span class="title-line title-2">Of One Operator</span>
    </h1>
    <p class="byline">
      <span class="hand byline-hand">drawn from forty years of plates &amp; field notes —</span>
      <em>Farshad Nayeri, of {profile.location}</em>
    </p>

    <figure class="plate">
      <div class="plate-frame">
        <div class="plate-corner tl" aria-hidden="true"></div>
        <div class="plate-corner tr" aria-hidden="true"></div>
        <div class="plate-corner bl" aria-hidden="true"></div>
        <div class="plate-corner br" aria-hidden="true"></div>

        <svg viewBox="0 0 800 540" class="plate-svg pen-draw" aria-labelledby="plate-title">
          <title id="plate-title">An Atlas of One Operator — five territories</title>

          <!-- decorative outer rule -->
          <rect x="20" y="20" width="760" height="500" fill="none" stroke="currentColor" stroke-width="0.6" style="--len: 2520; --d: 0" data-delay />
          <rect x="32" y="32" width="736" height="476" fill="none" stroke="currentColor" stroke-width="0.4" stroke-dasharray="3 3" style="--len: 2424; --d: 80" data-delay />

          <!-- five territories: hand-drawn coastlines -->
          <!-- North: Product Builder -->
          <g class="territory">
            <path d="M260 90 C 320 60, 410 60, 470 90 C 510 120, 520 160, 480 175 C 440 190, 360 192, 300 175 C 250 160, 230 120, 260 90 Z"
                  fill="rgba(177,74,55,0.07)" stroke="currentColor" stroke-width="1.1" style="--len: 1100; --d: 200" data-delay />
            <text x="365" y="135" text-anchor="middle" font-family="IM Fell English, serif" font-size="20" fill="currentColor">PRODUCT BUILDER</text>
            <text x="365" y="158" text-anchor="middle" font-family="Caveat, cursive" font-size="14" fill="rgba(34,26,16,0.65)">— ships the artifact —</text>
          </g>

          <!-- East: Data Storyteller -->
          <g class="territory">
            <path d="M560 200 C 620 180, 700 200, 720 250 C 730 290, 700 330, 640 340 C 580 348, 540 320, 540 280 C 540 240, 540 220, 560 200 Z"
                  fill="rgba(63,108,100,0.10)" stroke="currentColor" stroke-width="1.1" style="--len: 1100; --d: 360" data-delay />
            <text x="630" y="265" text-anchor="middle" font-family="IM Fell English, serif" font-size="18" fill="currentColor">DATA STORYTELLER</text>
            <text x="630" y="288" text-anchor="middle" font-family="Caveat, cursive" font-size="14" fill="rgba(34,26,16,0.65)">— directs the scene —</text>
          </g>

          <!-- South-East: Strategist -->
          <g class="territory">
            <path d="M460 380 C 520 360, 600 380, 620 420 C 630 450, 600 480, 540 485 C 480 488, 440 470, 440 440 C 440 415, 440 395, 460 380 Z"
                  fill="rgba(177,74,55,0.06)" stroke="currentColor" stroke-width="1.1" style="--len: 1100; --d: 520" data-delay />
            <text x="530" y="430" text-anchor="middle" font-family="IM Fell English, serif" font-size="18" fill="currentColor">STRATEGIST</text>
            <text x="530" y="453" text-anchor="middle" font-family="Caveat, cursive" font-size="14" fill="rgba(34,26,16,0.65)">— Christensen-trained —</text>
          </g>

          <!-- South-West: Founder -->
          <g class="territory">
            <path d="M180 400 C 240 378, 320 400, 340 442 C 350 472, 320 498, 260 500 C 200 502, 160 480, 160 452 C 160 428, 160 414, 180 400 Z"
                  fill="rgba(63,108,100,0.08)" stroke="currentColor" stroke-width="1.1" style="--len: 1100; --d: 680" data-delay />
            <text x="250" y="450" text-anchor="middle" font-family="IM Fell English, serif" font-size="18" fill="currentColor">FOUNDER</text>
            <text x="250" y="473" text-anchor="middle" font-family="Caveat, cursive" font-size="14" fill="rgba(34,26,16,0.65)">— three companies, thirty years —</text>
          </g>

          <!-- West: Developer Tools -->
          <g class="territory">
            <path d="M80 200 C 140 180, 220 200, 240 250 C 250 290, 220 330, 160 340 C 100 348, 60 320, 60 280 C 60 240, 60 220, 80 200 Z"
                  fill="rgba(177,74,55,0.07)" stroke="currentColor" stroke-width="1.1" style="--len: 1100; --d: 840" data-delay />
            <text x="150" y="265" text-anchor="middle" font-family="IM Fell English, serif" font-size="18" fill="currentColor">DEV TOOLS</text>
            <text x="150" y="288" text-anchor="middle" font-family="Caveat, cursive" font-size="14" fill="rgba(34,26,16,0.65)">— Modula-3 lineage —</text>
          </g>

          <!-- centre island: the operator -->
          <g class="island">
            <ellipse cx="400" cy="270" rx="80" ry="58" fill="var(--parchment-3)" stroke="currentColor" stroke-width="1.2" style="--len: 440; --d: 1000" data-delay />
            <ellipse cx="400" cy="270" rx="60" ry="42" fill="none" stroke="currentColor" stroke-width="0.4" stroke-dasharray="2 3" style="--len: 320; --d: 1100" data-delay />
            <text x="400" y="262" text-anchor="middle" font-family="IM Fell English SC, serif" font-size="16" letter-spacing="0.15em" fill="currentColor">FARSHAD</text>
            <text x="400" y="284" text-anchor="middle" font-family="IM Fell English SC, serif" font-size="16" letter-spacing="0.15em" fill="currentColor">NAYERI</text>
          </g>

          <!-- compass rose, lower-right -->
          <g class="rose" transform="translate(710, 420)">
            <circle cx="0" cy="0" r="36" fill="none" stroke="currentColor" stroke-width="0.8" style="--len: 230; --d: 1240" data-delay />
            <circle cx="0" cy="0" r="22" fill="none" stroke="currentColor" stroke-width="0.4" stroke-dasharray="2 2" style="--len: 140; --d: 1300" data-delay />
            <polygon points="0,-36 4,0 0,-6 -4,0" fill="currentColor" />
            <polygon points="0,36 4,0 0,6 -4,0" fill="currentColor" opacity="0.5" />
            <text x="0" y="-42" text-anchor="middle" font-family="IM Fell English SC, serif" font-size="9" letter-spacing="0.12em" fill="currentColor">N</text>
          </g>

          <!-- scale legend, lower-left -->
          <g class="legend" transform="translate(60, 470)">
            <line x1="0" y1="0" x2="120" y2="0" stroke="currentColor" stroke-width="1" style="--len: 120; --d: 1280" data-delay />
            <line x1="0" y1="-4" x2="0" y2="4" stroke="currentColor" stroke-width="1" style="--len: 8; --d: 1280" data-delay />
            <line x1="60" y1="-3" x2="60" y2="3" stroke="currentColor" stroke-width="1" style="--len: 6; --d: 1280" data-delay />
            <line x1="120" y1="-4" x2="120" y2="4" stroke="currentColor" stroke-width="1" style="--len: 8; --d: 1280" data-delay />
            <text x="0" y="18" font-family="IM Fell English SC, serif" font-size="9" letter-spacing="0.12em" fill="currentColor">1985</text>
            <text x="60" y="18" text-anchor="middle" font-family="IM Fell English SC, serif" font-size="9" letter-spacing="0.12em" fill="currentColor">2005</text>
            <text x="120" y="18" text-anchor="end" font-family="IM Fell English SC, serif" font-size="9" letter-spacing="0.12em" fill="currentColor">2026</text>
            <text x="60" y="32" text-anchor="middle" font-family="Caveat, cursive" font-size="13" fill="rgba(34,26,16,0.65)">a working life</text>
          </g>

          <!-- annotations -->
          <text x="500" y="245" font-family="Caveat, cursive" font-size="14" fill="var(--rust)">↗ exports to all four</text>
          <text x="320" y="220" font-family="Caveat, cursive" font-size="13" fill="var(--rust)" text-anchor="end">↖ Pixxa</text>
          <text x="500" y="365" font-family="Caveat, cursive" font-size="13" fill="var(--rust)">↘ EY · Fidelity · Baupost</text>
          <text x="270" y="365" font-family="Caveat, cursive" font-size="13" fill="var(--rust)" text-anchor="end">↙ Critical Mass · iGEN</text>
          <text x="170" y="220" font-family="Caveat, cursive" font-size="13" fill="var(--rust)" text-anchor="end">⤺ DEC SRC lineage</text>
        </svg>
      </div>
      <figcaption class="plate-cap">
        <span class="banner">Plate I.</span>
        <span class="cap-text">
          <em>An Atlas of One Operator.</em> Five territories, one island. Drawn from a working life in Boston, Cambridge, and (occasionally) the cities the work travels to. <span class="hand">Use the bearings below to navigate by lens.</span>
        </span>
      </figcaption>
    </figure>

    <p class="throughline">
      <span class="dropcap">I</span> {profile.throughline.replace(/^I\s/, "")}
    </p>
  </div>
</section>

<style>
  .frontispiece { padding: clamp(40px, 6vw, 96px) 0 clamp(36px, 4vw, 72px); border-bottom: 3px double var(--ink); }
  .series {
    font-family: var(--press-sc);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rust);
    margin: 0 0 28px;
    text-align: center;
  }
  .title {
    margin: 0 0 14px;
    text-align: center;
    font-family: var(--press);
    line-height: 0.95;
  }
  .title-line { display: inline-block; }
  .title-1 {
    font-size: var(--step-5);
    font-weight: 400;
    letter-spacing: -0.012em;
  }
  .title-amp {
    display: inline-block;
    font-style: italic;
    color: var(--rust);
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    margin: 0 0.2em;
    transform: translateY(-0.04em);
  }
  .title-2 {
    font-family: var(--press-sc);
    font-size: clamp(1.75rem, 3vw, 2.6rem);
    letter-spacing: 0.18em;
    color: var(--ink-soft);
    display: block;
    margin-top: 6px;
  }
  .byline {
    text-align: center;
    margin: 0 0 36px;
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .byline-hand {
    display: block;
    font-size: 22px;
    color: var(--rust);
    margin-bottom: 4px;
  }
  .plate {
    margin: 0;
    padding: 14px;
    background: var(--parchment-2);
    border: 1px solid var(--ink);
    box-shadow: 6px 6px 0 var(--parchment-3);
  }
  .plate-frame {
    position: relative;
    background: var(--parchment);
    padding: 18px 22px 26px;
    border: 1px solid var(--rule);
  }
  .plate-corner {
    position: absolute;
    width: 22px; height: 22px;
    border: 1px solid var(--ink);
  }
  .plate-corner.tl { top: 6px; left: 6px; border-right: 0; border-bottom: 0; }
  .plate-corner.tr { top: 6px; right: 6px; border-left: 0; border-bottom: 0; }
  .plate-corner.bl { bottom: 6px; left: 6px; border-right: 0; border-top: 0; }
  .plate-corner.br { bottom: 6px; right: 6px; border-left: 0; border-top: 0; }
  .plate-svg {
    width: 100%;
    height: auto;
    color: var(--ink);
    display: block;
  }
  .plate-cap {
    margin-top: 14px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
  }
  .cap-text {
    font-family: var(--press);
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .cap-text em { color: var(--ink); }
  .cap-text .hand { font-size: 18px; color: var(--rust); }
  .throughline {
    margin: 40px auto 0;
    max-width: 36em;
    font-size: var(--step-2);
    line-height: 1.4;
    text-align: center;
    color: var(--ink);
    font-style: italic;
  }
  .dropcap {
    float: left;
    font-family: var(--press);
    font-size: 4.4em;
    line-height: 0.85;
    margin: 0.05em 0.08em 0 0;
    color: var(--rust);
    font-style: normal;
  }
</style>

---
import { personas } from "../lib/content.ts";
const { active } = Astro.props as { active: string };
const dirs = ["N", "NE", "E", "SE", "SW"];
---

<nav class="compass" aria-label="Choose a bearing (persona)">
  <div class="compass-rose" aria-hidden="true">
    <svg viewBox="0 0 220 220" width="220" height="220" class="pen-draw">
      <circle cx="110" cy="110" r="100" fill="none" stroke="currentColor" stroke-width="1" style="--len: 630" />
      <circle cx="110" cy="110" r="80" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 3" style="--len: 504" />
      <circle cx="110" cy="110" r="50" fill="none" stroke="currentColor" stroke-width="0.5" style="--len: 314" />
      <line x1="110" y1="10" x2="110" y2="210" stroke="currentColor" stroke-width="0.5" style="--len: 200" />
      <line x1="10" y1="110" x2="210" y2="110" stroke="currentColor" stroke-width="0.5" style="--len: 200" />
      <line x1="40" y1="40" x2="180" y2="180" stroke="currentColor" stroke-width="0.4" style="--len: 200" />
      <line x1="180" y1="40" x2="40" y2="180" stroke="currentColor" stroke-width="0.4" style="--len: 200" />
      <polygon points="110,18 116,110 110,98 104,110" fill="currentColor" />
      <polygon points="110,202 116,110 110,122 104,110" fill="currentColor" opacity="0.4" />
    </svg>
  </div>
  <ul class="compass-list">
    {personas.map((p, i) => (
      <li>
        <a href={`/for/${p.id}/`} class={p.id === active ? "is-active" : ""} title={p.pitch_line}>
          <span class="bearing">{dirs[i]}</span>
          <span class="bearing-label">{p.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .compass {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: clamp(20px, 3vw, 48px);
    align-items: center;
    padding: 28px 0;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    margin: clamp(28px, 4vw, 56px) 0;
    color: var(--ink);
  }
  .compass-rose { display: flex; justify-content: center; }
  .compass-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 6px 24px;
  }
  .compass-list li { display: block; }
  .compass-list a {
    display: grid;
    grid-template-columns: 36px 1fr;
    align-items: baseline;
    gap: 12px;
    padding: 6px 0;
    background: none;
    color: var(--ink);
    border-bottom: 1px dotted transparent;
  }
  .compass-list a:hover { color: var(--rust); border-bottom-color: var(--rust); }
  .compass-list .is-active { color: var(--rust); border-bottom: 1px solid var(--rust); }
  .bearing {
    font-family: var(--press-sc);
    font-size: 13px;
    letter-spacing: 0.12em;
    color: var(--rust);
    text-align: center;
    padding-top: 2px;
  }
  .bearing-label {
    font-family: var(--press);
    font-size: 18px;
    line-height: 1.2;
  }
  @media (max-width: 760px) {
    .compass { grid-template-columns: 1fr; }
    .compass-list { grid-template-columns: 1fr; }
  }
</style>

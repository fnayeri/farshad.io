---
import Base from "../layouts/Base.astro";
import Spectrum from "../components/Spectrum.astro";
import LogoWall from "../components/LogoWall.astro";
import CategoryLegend from "../components/CategoryLegend.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { profile, defaultPersona, projectsForPersona, testimonials } from "../lib/content.ts";

const persona = defaultPersona();
const featured = projectsForPersona(persona.id).slice(0, 4);
const heroQuotes = testimonials.slice(0, 3);
---

<Base title="Farshad Nayeri — Boston" description={profile.throughline} active="home">
  <section class="container hero">
    <p class="label">Farshad Nayeri · Boston</p>
    <h1 class="hero-title">{profile.throughline}</h1>
    <p class="hero-sub">
      Builder, strategist, and data cinematographer. Five categories of work; one operator.
    </p>
  </section>

  <div class="container">
    <CategoryLegend />
  </div>

  <div class="container">
    <Spectrum />
  </div>

  <section class="container featured">
    <header class="section-head">
      <p class="label">Featured</p>
      <h2>Selected work — {persona.label}</h2>
      <a href="/work/" class="more">All work →</a>
    </header>
    <div class="grid">
      {featured.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>

  <div class="container"><LogoWall /></div>

  <section class="container press">
    <header class="section-head">
      <p class="label">Press</p>
      <h2>What people have said.</h2>
    </header>
    <div class="quotes">
      {heroQuotes.map((t) => (
        <figure class="quote">
          <blockquote>{t.quote}</blockquote>
          <figcaption>
            <span class="qname">{t.name}</span>
            <span class="qtitle">{t.title}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero { padding: clamp(40px, 6vw, 96px) 0 16px; }
  .hero-title {
    font-size: var(--step-5);
    line-height: 1.0;
    letter-spacing: -0.04em;
    font-weight: 700;
    margin: 12px 0 18px;
    max-width: 22ch;
  }
  .hero-sub {
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--ink-soft);
    max-width: 36ch;
    margin: 0;
    font-weight: 400;
  }
  .featured { padding: 64px 0; }
  .section-head {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 16px;
    align-items: baseline;
    margin-bottom: 24px;
    border-top: 1px solid var(--rule);
    padding-top: 18px;
  }
  .section-head h2 {
    grid-column: 1;
    margin: 6px 0 0;
    font-size: var(--step-3);
  }
  .section-head .more {
    grid-row: 2;
    grid-column: 2;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    font-weight: 500;
    font-size: 13px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }
  .press { padding: 32px 0 64px; }
  .quotes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .quote {
    margin: 0;
    padding: 22px 0;
    border-top: 2px solid var(--ink);
  }
  .quote blockquote {
    margin: 0 0 14px;
    padding: 0;
    border: 0;
    font-size: var(--step-2);
    line-height: 1.25;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .qname {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }
  .qtitle {
    display: block;
    font-size: 13px;
    color: var(--ink-quiet);
  }
</style>

---
import Base from "../../layouts/Base.astro";
import CategoryLegend from "../../components/CategoryLegend.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import {
  personas,
  testimonials,
  projects,
  getPersona,
  type Persona,
} from "../../lib/content.ts";
import { CATEGORY_COLORS } from "../../lib/categories.ts";

export function getStaticPaths() {
  return personas.map((p) => ({ params: { persona: p.id } }));
}

const { persona: personaId } = Astro.params;
const persona = getPersona(personaId!) as Persona;
const c = CATEGORY_COLORS[persona.id];
const featured = persona.featured_project_slugs
  .map((slug) => projects.find((p) => p.slug === slug))
  .filter(Boolean) as typeof projects;
const personaQuotes = testimonials.filter((t) => t.personas.includes(persona.id));
const allInCategory = projects.filter((p) => p.personas.includes(persona.id));
---

<Base title={`${persona.label} — Farshad Nayeri`} description={persona.pitch_line} active="home">
  <section class="container hero" style={`--c:${c.hex}`}>
    <p class="label cat-label"><span class="dot" style={`background:${c.hex}`}></span>{c.name}</p>
    <h1 class="hero-title">{persona.label}</h1>
    <p class="hero-pitch">{persona.pitch_line}</p>
    <div class="actions">
      <a href="/work/" class="btn">All work →</a>
      <button type="button" class="btn btn-ghost" onclick="window.print();">Print one-pager</button>
    </div>
  </section>

  <div class="container"><CategoryLegend active={persona.id} /></div>

  <article class="container body-grid">
    <div class="prose">
      <h2>The shape of the gap</h2>
      <p>{persona.shape_of_the_gap}</p>
      <h2>What he uniquely does</h2>
      <p>{persona.what_he_uniquely_does}</p>
      <h2>Angles to play</h2>
      <ol>
        {persona.angles_to_play.map((a) => <li>{a}</li>)}
      </ol>
      <h2>What this is not</h2>
      <p>{persona.head_off_early}</p>
      <p class="closing" style={`border-color:${c.hex}`}>{persona.closing_pitch}</p>
    </div>
    <aside class="side">
      <div class="side-section">
        <p class="label">Credibility</p>
        <ol class="anchor-list">
          {persona.credibility_anchors.map((a) => <li>{a}</li>)}
        </ol>
      </div>
      {personaQuotes.length > 0 && (
        <div class="side-section">
          <p class="label">Press</p>
          {personaQuotes.map((t) => (
            <figure class="mini-q">
              <blockquote>{t.quote}</blockquote>
              <figcaption>
                <strong>{t.name}</strong>
                <span>{t.title}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      )}
    </aside>
  </article>

  <section class="container featured">
    <header class="section-head">
      <p class="label">Featured</p>
      <h2>{c.name} — selected work</h2>
      <span class="head-meta tnum">{allInCategory.length} projects in this category</span>
    </header>
    <div class="grid">
      {featured.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: clamp(40px, 6vw, 96px) 0 28px;
    border-bottom: 1px solid var(--rule);
  }
  .cat-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--c);
    margin: 0 0 16px;
  }
  .hero-title {
    font-size: var(--step-5);
    line-height: 1.0;
    letter-spacing: -0.04em;
    margin: 0 0 14px;
  }
  .hero-pitch {
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--ink-soft);
    max-width: 36ch;
    margin: 0 0 22px;
  }
  .actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn {
    display: inline-block;
    padding: 8px 14px;
    border: 1px solid var(--ink);
    color: var(--ink);
    background: var(--ink);
    color: var(--bg);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 4px;
  }
  .btn:hover { filter: brightness(1.1); }
  .btn-ghost {
    background: transparent;
    color: var(--ink);
  }
  .btn-ghost:hover { background: var(--ink); color: var(--bg); }
  .body-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: clamp(28px, 4vw, 64px);
    padding: 48px 0;
  }
  .prose h2 {
    font-size: var(--step-1);
    margin-top: 32px;
    margin-bottom: 10px;
    border-top: 1px solid var(--rule);
    padding-top: 16px;
    font-weight: 600;
  }
  .prose h2:first-of-type { margin-top: 0; border-top: 0; padding-top: 0; }
  .prose ol { padding-left: 1.2em; }
  .prose ol li { line-height: 1.6; margin-bottom: 8px; }
  .closing {
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--ink);
    margin: 32px 0 0;
    padding: 24px 0 0;
    border-top: 3px solid;
    font-weight: 500;
  }
  .side { padding-top: 0; }
  .side-section { margin-bottom: 32px; }
  .side-section .label { display: block; margin-bottom: 14px; }
  .anchor-list {
    list-style: decimal;
    padding-left: 1.2em;
    margin: 0;
  }
  .anchor-list li {
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 12px;
  }
  .mini-q {
    margin: 0 0 16px;
    padding: 14px 0;
    border-top: 1px solid var(--rule);
  }
  .mini-q blockquote {
    margin: 0 0 8px;
    border: 0;
    padding: 0;
    font-size: 14px;
    line-height: 1.4;
    color: var(--ink);
    font-style: italic;
  }
  .mini-q figcaption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 12px;
    color: var(--ink-quiet);
  }
  .mini-q figcaption strong { color: var(--ink); }
  .featured { padding: 32px 0 64px; }
  .section-head {
    display: grid;
    grid-template-columns: 1fr auto;
    column-gap: 16px;
    align-items: baseline;
    border-top: 1px solid var(--rule);
    padding-top: 18px;
    margin-bottom: 22px;
  }
  .section-head h2 {
    grid-column: 1;
    margin: 6px 0 0;
    font-size: var(--step-3);
  }
  .section-head .head-meta {
    grid-column: 2;
    grid-row: 2;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-quiet);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }
  @media (max-width: 900px) { .body-grid { grid-template-columns: 1fr; } }
</style>

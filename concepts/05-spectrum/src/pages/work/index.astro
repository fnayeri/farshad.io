---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import CategoryLegend from "../../components/CategoryLegend.astro";
import { projects, personas } from "../../lib/content.ts";
---

<Base title="Work — Farshad Nayeri" description="The full project archive." active="work">
  <section class="container head">
    <p class="label">Archive</p>
    <h1>All work</h1>
    <p class="lede tnum">{projects.length} projects across five categories.</p>
  </section>

  <div class="container">
    <nav class="filter" aria-label="Filter by category">
      <span class="label">Filter</span>
      <a href="#all" class="chip is-active">All</a>
      {personas.map((p) => (
        <a href={`#${p.id}`} class={`chip cat-${p.id}`} data-cat={p.id}>{p.label}</a>
      ))}
    </nav>
  </div>

  <section class="container grid-section">
    <div class="grid">
      {projects.map((p) => (
        <div class="grid-item" data-personas={p.personas.join(",")}>
          <ProjectCard project={p} />
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    (function () {
      var chips = document.querySelectorAll(".chip");
      var items = document.querySelectorAll(".grid-item");
      function filter(t) {
        chips.forEach(function (c) {
          c.classList.toggle("is-active", c.getAttribute("href") === "#" + t);
        });
        items.forEach(function (it) {
          var ps = (it.getAttribute("data-personas") || "").split(",");
          it.style.display = t === "all" || ps.indexOf(t) !== -1 ? "" : "none";
        });
      }
      chips.forEach(function (c) {
        c.addEventListener("click", function (e) {
          e.preventDefault();
          var t = (c.getAttribute("href") || "#all").slice(1);
          history.replaceState(null, "", "#" + t);
          filter(t);
        });
      });
      filter(location.hash ? location.hash.slice(1) : "all");
    })();
  </script>
</Base>

<style>
  .head { padding: clamp(40px, 6vw, 96px) 0 16px; max-width: 60ch; }
  h1 { font-size: var(--step-5); margin: 8px 0 14px; }
  .lede { font-size: var(--step-1); color: var(--ink-soft); margin: 0; }
  .filter {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px 12px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 16px 0;
    margin: 32px 0 32px;
  }
  .filter .label { margin-right: 6px; }
  .chip {
    display: inline-block;
    padding: 6px 12px;
    border: 1px solid var(--rule);
    border-radius: 999px;
    text-decoration: none;
    color: var(--ink-soft);
    font-size: 13px;
    font-weight: 500;
    transition: background var(--t-quick), color var(--t-quick), border-color var(--t-quick);
  }
  .chip:hover { color: var(--ink); border-color: var(--ink); }
  .chip.is-active {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .chip.cat-product-builder.is-active  { background: var(--cat-builder); border-color: var(--cat-builder); }
  .chip.cat-data-storyteller.is-active { background: var(--cat-storyteller); border-color: var(--cat-storyteller); }
  .chip.cat-strategist.is-active       { background: var(--cat-strategist); border-color: var(--cat-strategist); }
  .chip.cat-founder.is-active          { background: var(--cat-founder); border-color: var(--cat-founder); }
  .chip.cat-dev-tools.is-active        { background: var(--cat-devtools); border-color: var(--cat-devtools); }
  .grid-section { padding-bottom: 64px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }
</style>

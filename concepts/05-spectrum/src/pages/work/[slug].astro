---
import Base from "../../layouts/Base.astro";
import { projects, getProjectModule, personas as allPersonas } from "../../lib/content.ts";
import { CATEGORY_COLORS } from "../../lib/categories.ts";
import { projectLogo, projectArtifacts } from "../../lib/assets.ts";
import CategoryIcon from "../../components/CategoryIcon.astro";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const mod = getProjectModule(slug!);
if (!mod) throw new Error("Project not found: " + slug);
const { frontmatter, Content } = mod;
const wordmark = frontmatter.client.replace(/\s*\(founder\)$/i, "").trim();
const cats = frontmatter.personas;
const personaItems = cats
  .map((id) => allPersonas.find((p) => p.id === id))
  .filter(Boolean) as Array<{ id: string; label: string }>;
const logo = projectLogo(slug!);
const artifacts = projectArtifacts(slug!);
---

<Base title={`${frontmatter.title} — Farshad Nayeri`} description={frontmatter.outcome} active="work">
  <article>
    <header class="case-hero">
      <div class="case-stripe" aria-hidden="true">
        {cats.map((cid) => (
          <span style={`background:${CATEGORY_COLORS[cid]?.hex || "#999"}`}></span>
        ))}
      </div>
      <div class="container case-hero-inner">
        <p class="label tnum">{frontmatter.dates}</p>
        <div class="case-mark">
          {logo ? (
            <img class="case-logo" src={logo} alt={`${wordmark} logo`} decoding="async" />
          ) : (
            <span class="case-wordmark">{wordmark}</span>
          )}
        </div>
        <h1>{frontmatter.title}</h1>
        <p class="outcome">{frontmatter.outcome}</p>
        <ul class="cat-row">
          {personaItems.map((p) => {
            const c = CATEGORY_COLORS[p.id];
            return (
              <li style={`color:${c.hex}`}>
                <CategoryIcon id={p.id} size={14} stroke={1.5} />
                <a href={`/for/${p.id}/`} style={`color:${c.hex}`}>{p.label}</a>
              </li>
            );
          })}
        </ul>
      </div>
    </header>

    {artifacts.length > 0 && (
      <section class="container artifacts" aria-label="Project artifacts">
        <p class="label">Artifacts</p>
        <div class={`artifact-grid artifact-grid-${Math.min(artifacts.length, 3)}`}>
          {artifacts.map((a) => (
            <figure class="artifact">
              {a.kind === "video" ? (
                <video src={a.src} poster={a.poster} controls playsinline preload="metadata"></video>
              ) : (
                <img src={a.src} alt={a.alt} loading="lazy" decoding="async" />
              )}
              {a.alt && <figcaption>{a.alt}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )}

    <div class="container case-grid">
      <aside class="meta">
        <dl>
          <div><dt>Client</dt><dd>{frontmatter.client}</dd></div>
          <div><dt>Role</dt><dd>{frontmatter.role}</dd></div>
          <div><dt>Dates</dt><dd>{frontmatter.dates}</dd></div>
          {frontmatter.location && <div><dt>Location</dt><dd>{frontmatter.location}</dd></div>}
          {frontmatter.collaborators.length > 0 && (
            <div><dt>Collaborators</dt><dd>{frontmatter.collaborators.join(", ")}</dd></div>
          )}
          <div>
            <dt>Categories</dt>
            <dd>
              <ul class="meta-cats">
                {personaItems.map((p) => (
                  <li>
                    <span class="ico" style={`color:${CATEGORY_COLORS[p.id]?.hex || "#999"}`}>
                      <CategoryIcon id={p.id} size={12} stroke={1.4} />
                    </span>
                    <a href={`/for/${p.id}/`}>{p.label}</a>
                  </li>
                ))}
              </ul>
            </dd>
          </div>
        </dl>
      </aside>
      <div class="prose">
        <Content />
        <p class="back"><a href="/work/">← All work</a></p>
      </div>
    </div>
  </article>
</Base>

<style>
  .case-hero { border-bottom: 1px solid var(--rule); }
  .case-stripe { height: 8px; display: flex; }
  .case-stripe span { flex: 1; height: 100%; }
  .case-hero-inner {
    padding: clamp(40px, 6vw, 96px) 0 36px;
    max-width: 60ch;
  }
  .case-mark {
    display: flex;
    align-items: center;
    height: 64px;
    margin: 16px 0 14px;
  }
  .case-logo {
    max-height: 60px;
    width: auto;
    object-fit: contain;
  }
  .case-wordmark {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.0;
    color: var(--ink);
  }
  h1 {
    font-size: clamp(1.5rem, 2.4vw, 1.95rem);
    font-weight: 500;
    color: var(--ink-soft);
    margin: 0 0 16px;
  }
  .outcome {
    font-size: var(--step-2);
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 18px;
  }
  .cat-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }
  .cat-row li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .cat-row a { text-decoration: none; }
  .cat-row a:hover { text-decoration: underline; }

  .artifacts { padding: 32px 0 8px; }
  .artifacts .label { display: block; margin-bottom: 14px; }
  .artifact-grid {
    display: grid;
    gap: 14px;
  }
  .artifact-grid-1 { grid-template-columns: 1fr; }
  .artifact-grid-2 { grid-template-columns: repeat(2, 1fr); }
  .artifact-grid-3 { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 760px) {
    .artifact-grid-2, .artifact-grid-3 { grid-template-columns: 1fr; }
  }
  .artifact {
    margin: 0;
    background: var(--bg-2);
    border: 1px solid var(--rule);
  }
  .artifact img,
  .artifact video {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .artifact figcaption {
    padding: 10px 14px;
    font-size: 12px;
    color: var(--ink-quiet);
    border-top: 1px solid var(--rule);
  }

  .case-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: clamp(28px, 4vw, 64px);
    padding: 48px 0 64px;
  }
  .meta dl { margin: 0; }
  .meta div {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-bottom: 1px solid var(--rule);
    padding: 12px 0;
  }
  .meta div:first-child { border-top: 2px solid var(--ink); }
  .meta dt {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-quiet);
  }
  .meta dd { margin: 0; font-size: 14px; }
  .meta-cats { list-style: none; margin: 0; padding: 0; }
  .meta-cats li { display: flex; align-items: center; gap: 8px; padding: 2px 0; font-size: 13px; }
  .meta-cats .ico { display: inline-flex; }
  .meta-cats a { text-decoration: none; color: var(--ink); }
  .meta-cats a:hover { text-decoration: underline; }
  .prose :global(h2) {
    font-size: var(--step-1);
    margin-top: 32px;
    margin-bottom: 12px;
    border-top: 1px solid var(--rule);
    padding-top: 18px;
  }
  .prose :global(h2:first-of-type) { margin-top: 0; border-top: 0; padding-top: 0; }
  .prose :global(p) { font-size: var(--step-0); line-height: 1.7; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--ink);
    padding-left: 18px;
    margin: 1.5em 0;
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .back { margin-top: 32px; }
  .back a { font-size: 13px; color: var(--ink); text-decoration: underline; text-decoration-thickness: 1px; }
  @media (max-width: 760px) { .case-grid { grid-template-columns: 1fr; } }
</style>

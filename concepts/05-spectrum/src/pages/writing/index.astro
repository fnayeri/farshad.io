---
import Base from "../../layouts/Base.astro";
import { writing } from "../../lib/content.ts";
---

<Base title="Writing — Farshad Nayeri" description="Essays." active="writing">
  <section class="container">
    <header class="head">
      <p class="label">Writing</p>
      <h1>Essays</h1>
    </header>
    <ol class="list">
      {writing.map((w) => (
        <li>
          <a href={`/writing/${w.slug}/`}>
            <span class="date tnum">{w.date}</span>
            <span class="body">
              <strong>{w.title}</strong>
              <span class="desc">{w.description}</span>
            </span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</Base>

<style>
  .head { padding: clamp(40px, 6vw, 96px) 0 16px; max-width: 60ch; }
  h1 { font-size: var(--step-5); margin: 8px 0 14px; }
  .list { list-style: none; margin: 32px 0 64px; padding: 0; }
  .list li { border-top: 1px solid var(--rule); }
  .list li:last-child { border-bottom: 1px solid var(--rule); }
  .list a {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    gap: 24px;
    padding: 22px 0;
    text-decoration: none;
    color: var(--ink);
    align-items: baseline;
  }
  .list a:hover strong { text-decoration: underline; }
  .date { font-family: var(--mono); font-size: 12px; color: var(--ink-quiet); }
  .body strong { display: block; font-size: var(--step-2); margin-bottom: 4px; font-weight: 600; }
  .desc { font-size: 14px; color: var(--ink-soft); }
</style>

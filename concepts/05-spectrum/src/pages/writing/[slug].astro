---
import Base from "../../layouts/Base.astro";
import { writing, getWritingModule } from "../../lib/content.ts";

export function getStaticPaths() {
  return writing.map((w) => ({ params: { slug: w.slug } }));
}

const { slug } = Astro.params;
const mod = getWritingModule(slug!);
if (!mod) throw new Error("Essay not found: " + slug);
const { frontmatter, Content } = mod;
---

<Base title={`${frontmatter.title} — Farshad Nayeri`} description={frontmatter.description} active="writing">
  <article class="container">
    <header class="head">
      <p class="label tnum">Essay · {frontmatter.date}</p>
      <h1>{frontmatter.title}</h1>
      <p class="desc">{frontmatter.description}</p>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .head { padding: clamp(40px, 6vw, 96px) 0 16px; max-width: 40em; border-bottom: 1px solid var(--rule); }
  h1 { font-size: var(--step-4); margin: 8px 0 14px; }
  .desc { font-size: var(--step-1); color: var(--ink-soft); margin: 0 0 28px; }
  .prose { max-width: 40em; padding: 36px 0 64px; }
  .prose :global(p) { font-size: var(--step-0); line-height: 1.75; }
</style>

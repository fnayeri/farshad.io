---
import Base from "../layouts/Base.astro";
import { talks } from "../lib/content.ts";
const featured = talks.filter((t) => t.featured);
const rest = talks.filter((t) => !t.featured);
---

<Base title="Talks — Farshad Nayeri" description="Stage work." active="talks">
  <section class="container">
    <header class="head">
      <p class="label">Talks</p>
      <h1>Talks</h1>
      <p class="lede">From ECOOP 1994 to HarvardXR 2025.</p>
    </header>

    <div class="featured">
      {featured.map((t) => (
        <article class="t-feat">
          <span class="t-date tnum">{t.date}</span>
          <h2>{t.title}</h2>
          <p class="t-venue">{t.venue}</p>
          <p>{t.description}</p>
          {t.url && <p><a href={t.url} target="_blank" rel="noopener noreferrer">Visit ↗</a></p>}
        </article>
      ))}
    </div>

    <h3 class="other-h">Other talks</h3>
    <ol class="other">
      {rest.map((t) => (
        <li>
          <span class="t-date tnum">{t.date}</span>
          <div class="t-body">
            <strong>{t.title}</strong>
            <span class="t-venue">{t.venue}</span>
            <p>{t.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
</Base>

<style>
  .head { padding: clamp(40px, 6vw, 96px) 0 16px; max-width: 60ch; }
  h1 { font-size: var(--step-5); margin: 8px 0 14px; }
  .lede { font-size: var(--step-1); color: var(--ink-soft); }
  .featured {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
    border-top: 1px solid var(--rule);
    padding-top: 24px;
    margin-top: 32px;
  }
  .t-feat {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    padding: 22px 22px 18px;
    border-left: 3px solid var(--ink);
  }
  .t-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-quiet);
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 8px;
  }
  .t-feat h2 { font-size: var(--step-2); font-weight: 600; margin: 0 0 6px; letter-spacing: -0.012em; }
  .t-venue { font-size: 14px; color: var(--ink-soft); margin: 0 0 12px; }
  .t-feat p { font-size: 14px; line-height: 1.6; color: var(--ink-soft); }
  .other-h { margin: 56px 0 12px; font-size: var(--step-2); border-top: 1px solid var(--rule); padding-top: 18px; }
  .other { list-style: none; margin: 0 0 64px; padding: 0; }
  .other li {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    gap: 24px;
    border-top: 1px solid var(--rule);
    padding: 18px 0;
    align-items: baseline;
  }
  .other li:last-child { border-bottom: 1px solid var(--rule); }
  .t-body strong { display: block; font-size: var(--step-1); margin-bottom: 2px; font-weight: 600; }
  .t-body .t-venue { display: block; }
  .t-body p { font-size: 13px; color: var(--ink-soft); margin: 0; }
</style>

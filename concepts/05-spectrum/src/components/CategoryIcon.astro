---
const { id, size = 22, stroke = 1.6 } = Astro.props as { id: string; size?: number; stroke?: number };
---

{id === "product-builder" && (
  <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="3" width="18" height="18" rx="2" />
    <path d="M3 9 H 21" />
    <path d="M9 3 V 21" />
    <circle cx="15" cy="15" r="2" />
  </svg>
)}

{id === "data-storyteller" && (
  <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="9" />
    <circle cx="12" cy="12" r="4" />
    <path d="M12 3 V 7" />
    <path d="M12 17 V 21" />
    <path d="M3 12 H 7" />
    <path d="M17 12 H 21" />
  </svg>
)}

{id === "strategist" && (
  <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
    <circle cx="6" cy="6" r="2.5" />
    <circle cx="18" cy="6" r="2.5" />
    <circle cx="12" cy="18" r="2.5" />
    <path d="M7.6 7.8 L 11 15.8" />
    <path d="M16.4 7.8 L 13 15.8" />
    <path d="M8.5 6 L 15.5 6" />
  </svg>
)}

{id === "founder" && (
  <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 2 L 16 8 L 14 14 L 10 14 L 8 8 Z" />
    <path d="M10 14 L 8 21" />
    <path d="M14 14 L 16 21" />
    <circle cx="12" cy="9" r="1.4" />
  </svg>
)}

{id === "dev-tools" && (
  <svg viewBox="0 0 24 24" width={size} height={size} fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="4" width="18" height="16" rx="2" />
    <path d="M7 10 L 10 13 L 7 16" />
    <path d="M13 16 H 17" />
  </svg>
)}

---
import Base from "../layouts/Base.astro";
import Frontispiece from "../components/Frontispiece.astro";
import PersonaSentence from "../components/PersonaSentence.astro";
import { defaultPersona, projectsForPersona, testimonials, clients, personas } from "../lib/content.ts";
const persona = defaultPersona();
const featured = projectsForPersona(persona.id).slice(0, 4);
---

<Base title="Farshad Nayeri — A Monograph in Progress" description={persona.pitch_line} active="home">
  <Frontispiece />

  <section class="container">
    <PersonaSentence active={persona.id} />

    <article class="tufte intro-tufte">
      <div class="body">
        <h2>Preface</h2>
        <p>{persona.pitch_line}</p>
        <p>{persona.what_he_uniquely_does}</p>
        <p>{persona.shape_of_the_gap}</p>
        <p class="closing"><em>{persona.closing_pitch}</em></p>
        <p><a href={`/for/${persona.id}/`}>Read the full chapter →</a></p>
      </div>
      <aside class="marginalia">
        <aside class="note">
          <span class="note-num">¶ 1</span>
          The full bibliography of careers and credibility anchors begins on the persona pages, indexed at <code>/for/{personas[0].id}</code> through <code>/for/{personas[personas.length - 1].id}</code>.
        </aside>
        <aside class="note">
          <span class="note-num">¶ 2</span>
          The frontispiece reproduces the Critical Mass Inc. masthead recovered from a 1998 capture on archive.org. The terminal panel reconstructs the Reactor IDE startup sequence; original screenshots remain in the Critical Mass archive and are not yet digitized.
        </aside>
        <aside class="note">
          <span class="note-num">¶ 3</span>
          The default chapter mode is <em>Product Builder</em>; switch via the inline list above.
        </aside>
      </aside>
    </article>

    <section class="chapter">
      <header class="chapter-head">
        <span class="numeral">§ 02</span>
        <h2>Selected Work, in Brief</h2>
      </header>
      <ol class="brief-list">
        {featured.map((p) => (
          <li>
            <a href={`/work/${p.slug}/`}>
              <span class="brief-dates">{p.dates}</span>
              <span class="brief-body">
                <strong>{p.title}</strong>
                <span class="brief-client">{p.client}</span>
                <span class="brief-outcome">{p.outcome}</span>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="chapter">
      <header class="chapter-head">
        <span class="numeral">§ 03</span>
        <h2>Press, in the Margin</h2>
      </header>
      <div class="tufte">
        <div class="body">
          <p>
            From the Airshow tour and after. Quotes preserved verbatim; full citations live in the margin.
          </p>
          <ul class="press-list">
            {testimonials.map((t) => (
              <li>
                <em>“{t.quote}”</em>
                <br /><span class="press-attr">— {t.name}</span>
              </li>
            ))}
          </ul>
        </div>
        <aside class="marginalia">
          {testimonials.map((t, i) => (
            <aside class="note">
              <span class="note-num">¶ {String(i + 1).padStart(2, "0")}</span>
              <strong>{t.name}</strong>, {t.title}. Source: {t.source}.
            </aside>
          ))}
        </aside>
      </div>
    </section>

    <section class="chapter">
      <header class="chapter-head">
        <span class="numeral">§ 04</span>
        <h2>Clients, by Last Name</h2>
      </header>
      <p class="client-line">
        {clients.map((c, i) => <><span>{c}</span>{i < clients.length - 1 ? <span class="dot"> · </span> : null}</>)}
      </p>
    </section>
  </section>
</Base>

<style>
  .intro-tufte { padding: 32px 0; }
  .body h2:first-of-type { margin-top: 0; }
  .body h2 {
    font-family: var(--serif);
    font-size: var(--step-2);
    margin-top: 28px;
    margin-bottom: 12px;
  }
  .closing { font-style: italic; font-size: var(--step-1); color: var(--ink); }

  .chapter {
    border-top: 1px solid var(--rule);
    padding-top: 24px;
    margin-top: 48px;
  }
  .chapter-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 18px;
  }
  .chapter-head h2 { margin: 0; }
  .chapter-head .numeral { color: var(--lab); }

  .brief-list { list-style: none; margin: 0; padding: 0; }
  .brief-list li { border-top: 1px solid var(--rule); }
  .brief-list li:last-child { border-bottom: 1px solid var(--rule); }
  .brief-list a {
    display: grid;
    grid-template-columns: 130px minmax(0, 1fr);
    gap: 24px;
    padding: 18px 0;
    border: 0;
    align-items: baseline;
  }
  .brief-list a:hover strong { color: var(--lab); }
  .brief-dates {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-quiet);
  }
  .brief-body strong {
    display: block;
    font-family: var(--serif);
    font-size: var(--step-1);
    margin-bottom: 2px;
    color: var(--ink);
  }
  .brief-client {
    display: block;
    font-style: italic;
    color: var(--ink-soft);
    font-size: 14px;
    margin-bottom: 4px;
  }
  .brief-outcome { color: var(--ink-soft); font-size: 14px; }

  .press-list { list-style: none; margin: 0; padding: 0; }
  .press-list li {
    border-top: 1px solid var(--rule);
    padding: 16px 0;
    font-size: var(--step-1);
    line-height: 1.4;
  }
  .press-attr {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--lab);
    letter-spacing: 0.04em;
  }

  .client-line {
    font-family: var(--serif);
    font-size: var(--step-2);
    line-height: 1.4;
    color: var(--ink);
    border-top: 1px solid var(--rule);
    padding-top: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .client-line .dot { color: var(--lab); margin: 0 6px; }
</style>

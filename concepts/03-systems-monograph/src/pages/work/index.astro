---
import Base from "../../layouts/Base.astro";
import { projects, personas } from "../../lib/content.ts";
---

<Base title="Work — Farshad Nayeri" description="Index of projects." active="work">
  <section class="container">
    <header class="head">
      <p class="numeral">§ Work</p>
      <h1>Index of Projects</h1>
      <p class="standfirst">An alphabetical reading list. Use the inline filter to narrow by chapter mode.</p>
    </header>

    <nav class="filter" aria-label="Filter">
      <span class="smallcaps">Filter</span>
      <a href="#all" class="chip is-active">All</a>
      {personas.map((p) => (
        <a href={`#${p.id}`} class="chip">{p.label}</a>
      ))}
    </nav>

    <ol class="proj-list">
      {projects.map((p) => (
        <li class="proj" data-personas={p.personas.join(",")}>
          <a href={`/work/${p.slug}/`}>
            <span class="proj-num numeral">{p.dates}</span>
            <span>
              <strong>{p.title}</strong>
              <span class="proj-client"><em>{p.client}</em></span>
              <span class="proj-outcome">{p.outcome}</span>
            </span>
          </a>
        </li>
      ))}
    </ol>

    <script is:inline>
      (function () {
        var chips = document.querySelectorAll(".chip");
        var items = document.querySelectorAll(".proj");
        function filter(t) {
          chips.forEach(function (c) {
            c.classList.toggle("is-active", c.getAttribute("href") === "#" + t);
          });
          items.forEach(function (it) {
            var ps = (it.getAttribute("data-personas") || "").split(",");
            it.style.display = t === "all" || ps.indexOf(t) !== -1 ? "" : "none";
          });
        }
        chips.forEach(function (c) {
          c.addEventListener("click", function (e) {
            e.preventDefault();
            var t = (c.getAttribute("href") || "#all").slice(1);
            history.replaceState(null, "", "#" + t);
            filter(t);
          });
        });
        filter(location.hash ? location.hash.slice(1) : "all");
      })();
    </script>
  </section>
</Base>

<style>
  .head { padding: clamp(40px, 6vw, 96px) 0 24px; max-width: 60ch; }
  .numeral { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--lab); margin: 0 0 14px; }
  h1 { font-size: var(--step-5); margin: 0 0 14px; }
  .standfirst { font-size: var(--step-1); font-style: italic; color: var(--ink-soft); margin: 0 0 28px; }
  .filter {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 14px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 12px 0;
    margin-bottom: 24px;
  }
  .filter .smallcaps { margin-right: 12px; }
  .chip {
    border: 1px solid var(--rule);
    padding: 4px 12px;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }
  .chip:hover { color: var(--lab); border-color: var(--lab); }
  .chip.is-active {
    background: var(--lab);
    color: var(--paper);
    border-color: var(--lab);
  }
  .proj-list { list-style: none; margin: 0; padding: 0; }
  .proj { border-top: 1px solid var(--rule); }
  .proj:last-child { border-bottom: 1px solid var(--rule); }
  .proj a {
    display: grid;
    grid-template-columns: 130px minmax(0, 1fr);
    gap: 24px;
    padding: 18px 0;
    border: 0;
    align-items: baseline;
  }
  .proj a:hover strong { color: var(--lab); }
  .proj-num { color: var(--ink-quiet); }
  .proj strong { display: block; font-size: var(--step-1); margin-bottom: 2px; }
  .proj-client { display: block; color: var(--ink-soft); font-size: 14px; margin-bottom: 4px; }
  .proj-outcome { color: var(--ink-soft); font-size: 14px; }
</style>

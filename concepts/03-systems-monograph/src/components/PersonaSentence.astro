---
import { personas } from "../lib/content.ts";
const { active } = Astro.props as { active: string };
---

<p class="read-as">
  <span class="smallcaps">Read as</span>
  {personas.map((p, i) => (
    <>
      <a href={`/for/${p.id}/`} class={p.id === active ? "is-active" : ""} title={p.pitch_line}>{p.label}</a>
      {i < personas.length - 1 ? <span class="dot"> · </span> : null}
    </>
  ))}
</p>

<style>
  .read-as {
    margin: 0;
    padding: 14px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    font-family: var(--serif);
    font-size: 17px;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .read-as .smallcaps { margin-right: 12px; color: var(--lab); }
  .read-as a {
    border: 0;
    color: var(--ink-soft);
    padding-bottom: 1px;
  }
  .read-as a:hover { color: var(--lab); }
  .read-as a.is-active {
    color: var(--lab);
    font-weight: 600;
    border-bottom: 1px solid var(--lab);
  }
  .dot { color: var(--rule); margin: 0 4px; }
</style>

---
const { active = "" } = Astro.props as { active?: string };
const items = [
  { href: "/", label: "Frontispiece", id: "home" },
  { href: "/work/", label: "Work", id: "work" },
  { href: "/writing/", label: "Notes", id: "writing" },
  { href: "/talks/", label: "Talks", id: "talks" },
  { href: "/about/", label: "Bio", id: "about" },
  { href: "/contact/", label: "Contact", id: "contact" },
];
---

<header class="nav no-print">
  <div class="container nav-row">
    <a href="/" class="masthead">
      <span class="seal" aria-hidden="true">FN</span>
      <span class="masthead-title">
        <span class="masthead-name">Farshad Nayeri</span>
        <span class="masthead-tag">A Monograph in Progress</span>
      </span>
    </a>
    <nav aria-label="Primary">
      <ol>
        {items.map((it, i) => (
          <li>
            <span class="nav-num">§ {String(i + 1).padStart(2, "0")}</span>
            <a href={it.href} aria-current={active === it.id ? "page" : undefined}>{it.label}</a>
          </li>
        ))}
      </ol>
    </nav>
  </div>
</header>

<style>
  .nav {
    border-bottom: 2px solid var(--ink);
    background: var(--paper);
  }
  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    gap: 24px;
  }
  .masthead {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: 0;
    color: var(--ink);
  }
  .seal {
    width: 36px;
    height: 36px;
    border: 1.5px solid var(--ink);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.04em;
  }
  .masthead-title {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .masthead-name {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 17px;
  }
  .masthead-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-quiet);
    margin-top: 1px;
  }
  .nav ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 22px;
    align-items: baseline;
  }
  .nav li {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }
  .nav-num {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--lab);
    letter-spacing: 0.04em;
  }
  .nav a {
    border: 0;
    font-family: var(--serif);
    font-size: 14px;
    color: var(--ink-soft);
    padding-bottom: 1px;
  }
  .nav a:hover { color: var(--lab); }
  .nav a[aria-current="page"] {
    color: var(--lab);
    border-bottom: 1px solid var(--lab);
    font-weight: 600;
  }
  @media (max-width: 760px) {
    .nav-row { flex-direction: column; align-items: flex-start; }
  }
</style>
